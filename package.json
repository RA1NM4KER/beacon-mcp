{
  "name": "beacon-mcp",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "tsc",
    "test": "node --import tsx --test tests/**/*.test.ts",
